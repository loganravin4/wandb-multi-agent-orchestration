# Weights & Biases
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=loopprep

# Tavily (company research)
TAVILY_API_KEY=

# Groq (Whisper transcription — free at console.groq.com)
GROQ_API_KEY=

# Upstash Redis (session persistence — free at upstash.com)
# If left empty, sessions are stored in-memory (lost on restart)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# W&B Serverless Inference models (defaults shown — override if needed)
INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1
MODEL_JD_PARSER=meta-llama/Llama-3.1-8B-Instruct
MODEL_RESEARCH=meta-llama/Llama-3.3-70B-Instruct
MODEL_FORMAT=meta-llama/Llama-3.3-70B-Instruct
MODEL_INTERVIEWER=meta-llama/Llama-3.3-70B-Instruct
MODEL_DELIVERY=meta-llama/Llama-3.1-8B-Instruct
MODEL_REPORT=meta-llama/Llama-3.3-70B-Instruct

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend — set VITE_API_BASE to your Render URL in production
# In local dev this defaults to /api (proxied by Vite)
VITE_API_BASE=/api
