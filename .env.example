# Weights & Biases (required — backend won't start without these)
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=loopprep

# Tavily (required)
TAVILY_API_KEY=

# W&B Serverless Inference (OpenAI-compatible) — no Anthropic key needed.
# Authenticated with WANDB_API_KEY above. Override per-agent models if desired.
INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1
MODEL_JD_PARSER=meta-llama/Llama-3.1-8B-Instruct
MODEL_RESEARCH=meta-llama/Llama-3.3-70B-Instruct
MODEL_FORMAT=meta-llama/Llama-3.3-70B-Instruct
MODEL_INTERVIEWER=meta-llama/Llama-3.3-70B-Instruct
MODEL_DELIVERY=meta-llama/Llama-3.1-8B-Instruct
MODEL_REPORT=deepseek-ai/DeepSeek-V3-0324

# Whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (local dev only — Docker nginx proxies /api automatically)
VITE_API_BASE=/api
